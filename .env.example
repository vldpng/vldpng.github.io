# GEMINI_API_KEY: ключ для вызовов Gemini API (серверная часть).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: публичный URL, на котором размещён сайт.
# Используется для абсолютных ссылок, OAuth-колбэков и API-эндпоинтов.
APP_URL="MY_APP_URL"

# --- Altegio (alteg.io) онлайн-запись — только серверная часть ---
# Пока не заданы ОБА значения, форма записи использует реалистичные MOCK-данные.
# Partner token из маркетплейса Altegio:
#   https://app.alteg.io/appstore/developers/1
ALTEGIO_PARTNER_TOKEN=""
# Company (branch) id клиники в Altegio:
ALTEGIO_COMPANY_ID=""
